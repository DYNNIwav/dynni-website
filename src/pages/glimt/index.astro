---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<Base
  lang="nn"
  title="Glimt — Hald fast på kvarandre | DYNNI"
  description="Glimt er eit roleg, privat alternativ til Snapchat. Del glimt som forsvinn, samle dei næraste rundt eit bål kvar veke. Ende-til-ende-kryptert, ingen reklame, ingen algoritme."
  canonical="https://dynni.no/glimt"
  ogTitle="Glimt — Hald fast på kvarandre"
  ogDescription="Eit roleg, privat alternativ til Snapchat. Glimt som forsvinn, bål kvar veke, ende-til-ende-kryptert."
  bodyClass="glimt-page"
  themeColor="#0B1117"
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="nn" href="https://dynni.no/glimt" />
    <link rel="alternate" hreflang="en" href="https://dynni.no/en/glimt" />
    <link rel="stylesheet" href="/css/glimt.css" />
    <script src="/js/glimt.js" is:inline></script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Glimt',
      operatingSystem: 'iOS, Android',
      applicationCategory: 'SocialNetworkingApplication',
      description: 'Eit roleg, privat alternativ til Snapchat. Glimt som forsvinn, bål kvar veke, ende-til-ende-kryptert.',
      author: { '@type': 'Person', name: 'Pål Omland Eilevstjønn', alternateName: 'DYNNI' },
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'NOK' },
    })} />
  </Fragment>

  <canvas class="aurora-canvas" aria-hidden="true"></canvas>
  <div class="grain-layer" aria-hidden="true"></div>
  <div class="vignette" aria-hidden="true"></div>

  <Nav lang="nn">
    <div class="lang-switch" slot="lang-switch"><a href="/glimt" class="active">NO</a><a href="/en/glimt">EN</a></div>
    <div class="lang-switch" slot="lang-switch-mobile"><a href="/glimt" class="active">NO</a><a href="/en/glimt">EN</a></div>
  </Nav>

  <main>
    <section class="glimt-hero">
      <div class="glimt-hero-inner">
        <div class="glimt-hero-copy hero-dawn">
          <div class="glimt-badge"><img src="/assets/img/apps/glimt.png" alt="Glimt" /> Glimt</div>
          <h1><span class="h1-line">Livet går fort.</span><span class="h1-line ice">Hald fast på kvarandre.</span></h1>
          <p class="lede">
            År for år er det lett å skli frå dei som betyr mest. Ikkje med vilje, livet berre tek over. Glimt er ein roleg liten stad for å vere ein del av kvarandre sine dagar igjen.
          </p>
          <form class="waitlist" id="waitlist-form">
            <input type="email" id="waitlist-email" placeholder="E-posten din" required autocomplete="email" />
            <button type="submit"><span class="label">Bli med på ventelista</span></button>
          </form>
          <div>
            <p class="waitlist-note" id="waitlist-note">Vi sender deg ein invitasjon når Glimt opnar. Ingen spam, lovnad.</p>
            <div class="store-badges">
              <span class="store-badge soon"><i class="fab fa-apple"></i> App Store · kjem snart</span>
              <span class="store-badge soon"><i class="fab fa-google-play"></i> Google Play · kjem snart</span>
            </div>
          </div>
        </div>
        <div class="glimt-hero-phone">
          <div class="phone">
            <div class="phone-notch"></div>
            <div class="phone-screen phone-screen--hero"><div class="app-resting" aria-hidden="true"><img class="app-bear-img" src="/assets/img/apps/glimt.png" alt="Glimt" /><span class="app-word">Glimt</span><span class="app-hint">eit roleg lite glimt ventar</span></div></div>
          </div>
        </div>
      </div>
    </section>

    <section class="glimt-story" data-reveal>
      <p>
        Vi har aldri vore meir «kopla saman», og likevel meir åleine. Feeden er full av framande, men dei næraste blir borte i støyen. Glimt snur det: <span class="ice">ingen algoritme, ingen feed, ingen framande.</span> Berre venene du faktisk har valt, og små augneblinkar som forsvinn så snart dei er sett.
      </p>
    </section>

    <section class="glimt-features">
      <article class="feature reveal-up" data-reveal>
        <div class="feature-text">
          <span class="feature-kicker">Glimt</span>
          <h2>Augneblinkar som forsvinn</h2>
          <p>Del eit lite glimt frå dagen din. Det visest éin gong, så er det borte. Ingen feed å scrolle, ingen likes å jage, ingen press om å prestere.</p>
        </div>
        <div class="feature-phone">
          <div class="phone phone--sm"><div class="phone-notch"></div><div class="phone-screen"><span class="phone-placeholder">eit glimt, snart</span><span class="frost-wipe" aria-hidden="true"></span></div></div>
        </div>
      </article>

      <article class="feature feature--reverse reveal-up" data-reveal>
        <div class="feature-text">
          <span class="feature-kicker">Bål</span>
          <h2>Samle dei næraste rundt bålet</h2>
          <p>Éin gong i veka deler du eit lite vekeglimt med dei aller næraste. Eit roleg ritual, så de held fram med å vere ein del av kvarandre sine veker, ikkje berre kvarandre sine minne.</p>
        </div>
        <div class="feature-phone">
          <div class="phone phone--sm"><div class="phone-notch"></div><div class="phone-screen"><div class="campfire" aria-hidden="true"><span class="fire-glow"></span><span class="flame outer"></span><span class="flame inner"></span><span class="logs"></span></div><span class="ember-ring" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></span></div></div>
        </div>
      </article>

      <article class="feature reveal-up" data-reveal>
        <div class="feature-text">
          <span class="feature-kicker">Privat</span>
          <h2>Ende-til-ende-kryptert. På ekte.</h2>
          <p>Kvart glimt blir kryptert på telefonen din før det blir sendt. Berre vennen din kan opne det, ikkje vi, ikkje nokon andre. Det vi lagrar er uleseleg for oss.</p>
        </div>
        <div class="feature-phone">
          <div class="phone phone--sm"><div class="phone-notch"></div><div class="phone-screen"><i class="fa-solid fa-lock lock-motif" aria-hidden="true"></i></div></div>
        </div>
      </article>
    </section>

    <section class="glimt-values">
      <h2>Bygd for deg, ikkje for annonsørar</h2>
      <ul class="values-grid" data-reveal>
        <li><i class="fa-solid fa-eye-slash"></i><h3>Inga sporing</h3><p>Vi sporar deg ikkje på tvers av appar eller nett. Aldri.</p></li>
        <li><i class="fa-solid fa-ban"></i><h3>Ingen reklame</h3><p>Inga reklame, ingen algoritme som styrer kva du ser.</p></li>
        <li><i class="fa-solid fa-lock"></i><h3>Ende-til-ende</h3><p>Innhaldet ditt er kryptert. Vi kan ikkje lese det.</p></li>
        <li><i class="fa-solid fa-earth-europe"></i><h3>Europeisk</h3><p>Bygd i Noreg, GDPR i ryggrada, sel aldri dataa dine.</p></li>
      </ul>
    </section>

    <section class="glimt-cta">
      <h2>Bli med frå starten</h2>
      <p>Vi opnar Glimt for nokre få om gongen. Skriv deg på, så er du blant dei første.</p>
      <form class="waitlist" id="waitlist-form-2">
        <input type="email" id="waitlist-email-2" placeholder="E-posten din" required autocomplete="email" />
        <button type="submit"><span class="label">Bli med på ventelista</span></button>
      </form>
      <p class="waitlist-note" id="waitlist-note-2"></p>
    </section>
  </main>

  <Footer lang="nn">
    <p class="glimt-footer-links" slot="default">
      <a href="/glimt/privacy">Personvern</a> ·
      <a href="/glimt/terms">Vilkår</a> ·
      <a href="/glimt/child-safety">Barnetryggleik</a> ·
      <a href="/glimt/delete-account">Slett konto</a>
    </p>
  </Footer>

  <script is:inline>
    (function () {
      var SUPABASE_URL = 'https://khhjqjtmhybwfrkhttoa.supabase.co';
      var SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtoaGpxanRtaHlid2Zya2h0dG9hIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE5NDA4NjYsImV4cCI6MjA5NzUxNjg2Nn0.Xu1UKzzJzg2dO-4BdENCpVNQ4jJFUw9Iz4qOLb1NMCQ';
      function join(email) {
        return fetch(SUPABASE_URL + '/rest/v1/waitlist', {
          method: 'POST',
          headers: { 'apikey': SUPABASE_ANON, 'Authorization': 'Bearer ' + SUPABASE_ANON, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
          body: JSON.stringify({ email: email })
        });
      }
      function wire(formId, noteId) {
        var form = document.getElementById(formId);
        if (!form) return;
        var note = document.getElementById(noteId);
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var input = form.querySelector('input[type="email"]');
          var email = (input.value || '').trim();
          if (!email) return;
          form.classList.add('busy');
          join(email).then(function (res) {
            form.classList.remove('busy');
            if (res.ok) { form.classList.add('done'); if (note) note.textContent = 'Takk! Du er på lista. Vi seier frå når Glimt opnar. 🐻‍❄️'; input.value = ''; }
            else if (res.status === 409) { if (note) note.textContent = 'Du er allereie på lista. Takk! 🐻‍❄️'; }
            else { if (note) note.textContent = 'Noko gjekk gale. Prøv igjen, eller send ein e-post til paal@dynni.no.'; }
          }).catch(function () { form.classList.remove('busy'); if (note) note.textContent = 'Noko gjekk gale. Prøv igjen, eller send ein e-post til paal@dynni.no.'; });
        });
      }
      wire('waitlist-form', 'waitlist-note');
      wire('waitlist-form-2', 'waitlist-note-2');
    })();
  </script>
</Base>
